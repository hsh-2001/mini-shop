generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  description  String?
  address      String?
  phone        String?
  currencyBase String   @default("KHR") @map("currency_base")
  exchangeUSD  Decimal? @map("exchange_usd") @db.Decimal(10, 4)
  exchangeKHR  Decimal? @map("exchange_khr") @db.Decimal(10, 4)
  openingHours Json?    @map("opening_hours") // e.g., { "monday": "07:00-18:00", ... }

  createdOn DateTime @default(now()) @map("created_on")
  updatedOn DateTime @updatedAt @map("updated_on")

  users      User[]
  categories Category[]
  products   Product[]
  customers  Customer[]
  orders     Order[]
  suppliers  Supplier[]
  modifiers  Modifier[]
  shopDetail ShopDetail?

  @@map("shops")
}

model ShopDetail {
  id     Int  @id @default(autoincrement())
  shopId Int  @unique @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Additional details specific to coffee shops
  hasDriveThru Boolean @default(false) @map("has_drive_thru")
  hasSeating   Boolean @default(true) @map("has_seating")
  hasWifi      Boolean @default(true) @map("has_wifi")

  createdOn DateTime @default(now()) @map("created_on")
  updatedOn DateTime @updatedAt @map("updated_on")

  @@map("shop_details")
}

model User {
  id     Int  @id @default(autoincrement())
  shopId Int  @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  phone        String   @unique
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(STAFF)

  createdOn DateTime @default(now()) @map("created_on")
  updatedOn DateTime @updatedAt @map("updated_on")
  orders    Order[]

  @@map("users")
}

// ======================
// Menu & Products (Coffee-focused)
// ======================

model Category {
  id     Int  @id @default(autoincrement())
  shopId Int  @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name        String // e.g., "Hot Coffee", "Iced Drinks", "Pastries", "Syrups"
  type        CategoryType @default(DRINK)
  description String?

  products Product[]

  createdOn DateTime @default(now()) @map("created_on")
  updatedOn DateTime @updatedAt @map("updated_on")

  @@unique([shopId, name])
  @@map("categories")
}

model Product {
  id     Int  @id @default(autoincrement())
  shopId Int  @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  categoryId Int?      @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])

  name        String
  imageUrl    String? @map("image_url")
  description String?
  basePrice   Decimal @map("base_price") @db.Decimal(10, 2)

  // Coffee-specific
  size           String? // e.g., "Small", "Medium", "Large" — or use separate Size model for more flexibility
  isCustomizable Boolean @default(false) @map("is_customizable")

  sku     String? @unique
  barcode String?

  stock             Int     @default(-1) // For beans, milk, cups, pastries
  unit              String? @default("unit") // "ml", "g", "piece", "bag"
  lowStockThreshold Int?    @default(10) @map("low_stock_threshold")

  isActive Boolean @default(true) @map("is_active")

  // Relations
  orderItems       OrderItem[]
  productModifiers ProductModifier[]
  supplierProducts SupplierProduct[]

  createdOn DateTime @default(now()) @map("created_on")
  updatedOn DateTime @updatedAt @map("updated_on")

  @@map("products")
}

// Modifiers for customization (very important for coffee shops)
model Modifier {
  id     Int  @id @default(autoincrement())
  shopId Int  @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name  String // e.g., "Extra Shot", "Oat Milk", "Caramel Syrup"
  price Decimal @db.Decimal(8, 2)
  group String? // e.g., "Milk", "Syrup", "Shot" — for grouping in UI

  createdOn DateTime @default(now()) @map("created_on")
  updatedOn DateTime @updatedAt @map("updated_on")

  productModifiers ProductModifier[]

  @@map("modifiers")
}

model ProductModifier {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  modifierId Int      @map("modifier_id")
  modifier   Modifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)

  isDefault Boolean @default(false) @map("is_default")

  @@unique([productId, modifierId])
  @@map("product_modifiers")
}

// ======================
// Customers & Orders
// ======================

model Customer {
  id     Int  @id @default(autoincrement())
  shopId Int  @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name          String
  phone         String? @unique
  email         String?
  loyaltyPoints Int     @default(0) @map("loyalty_points")

  orders Order[]

  createdOn DateTime @default(now()) @map("created_on")
  updatedOn DateTime @updatedAt @map("updated_on")

  @@map("customers")
}

model Order {
  id     Int  @id @default(autoincrement())
  shopId Int  @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  customerId Int?      @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId Int  @map("user_id") // Barista / Cashier
  user   User @relation(fields: [userId], references: [id])

  orderNumber String      @unique @map("order_number")
  status      OrderStatus @default(PENDING)
  type        OrderType   @default(IN_STORE) // For takeaway, delivery, etc.

  subtotal    Decimal  @db.Decimal(12, 2)
  discount    Decimal? @default(0) @db.Decimal(10, 2)
  tax         Decimal? @default(0) @db.Decimal(10, 2)
  finalAmount Decimal  @map("final_amount") @db.Decimal(12, 2)

  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")

  notes String?

  orderItems OrderItem[]

  createdOn DateTime @default(now()) @map("created_on")
  updatedOn DateTime @updatedAt @map("updated_on")

  @@map("orders")
}

model OrderItem {
  id      Int   @id @default(autoincrement())
  orderId Int   @map("order_id")
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int     @default(1)
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(12, 2)

  // Selected modifiers for this item
  selectedModifiers Json? @map("selected_modifiers") // e.g., [{"name": "Oat Milk", "price": 0.5}, ...]

  createdOn DateTime @default(now()) @map("created_on")
  updatedOn DateTime @updatedAt @map("updated_on")

  @@map("order_items")
}

// ======================
// Suppliers & Inventory
// ======================

model Supplier {
  id     Int  @id @default(autoincrement())
  shopId Int  @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name          String
  contactPerson String? @map("contact_person")
  phone         String?
  email         String?

  supplierProducts SupplierProduct[]

  createdOn DateTime @default(now()) @map("created_on")
  updatedOn DateTime @updatedAt @map("updated_on")

  @@map("suppliers")
}

model SupplierProduct {
  supplierId Int      @map("supplier_id")
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  supplyPrice Decimal @map("supply_price") @db.Decimal(10, 2)

  @@id([supplierId, productId])
  @@map("supplier_products")
}

// ======================
// Enums
// ======================

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  BARISTA
  CASHIER
  STAFF
}

enum CategoryType {
  DRINK
  FOOD
  SUPPLY // cups, lids, napkins, cleaning
  BEAN
  SYRUP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  IN_STORE
  TAKEAWAY
  DELIVERY
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY // Wing, ABA, etc. (common in Cambodia)
  QR_CODE
  OTHER
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  REFUNDED
}
