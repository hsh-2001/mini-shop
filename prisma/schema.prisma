generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  phone         String   @unique
  username      String   @unique
  password_hash String
  created_on    DateTime @default(now())
  updated_on    DateTime
}
