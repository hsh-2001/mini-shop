generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id           Int         @id @default(autoincrement())
  name         String      @unique
  description  String?
  createdOn    DateTime    @default(now()) @map("created_on")
  updatedOn    DateTime    @updatedAt @map("updated_on")
  address      String?
  openingHours Json?       @map("opening_hours")
  phone        String?
  currencyBase String      @default("KHR") @map("currency_base")
  exchangeKHR  Decimal?    @map("exchange_khr") @db.Decimal(10, 6)
  exchangeUSD  Decimal?    @map("exchange_usd") @db.Decimal(10, 6)
  categories   Category[]
  customers    Customer[]
  modifiers    Modifier[]
  orders       Order[]
  products     Product[]
  shopDetail   ShopDetail?
  suppliers    Supplier[]
  users        User[]

  @@map("shops")
}

model ShopDetail {
  id           Int      @id @default(autoincrement())
  shopId       Int      @unique @map("shop_id")
  hasDriveThru Boolean  @default(false) @map("has_drive_thru")
  hasSeating   Boolean  @default(true) @map("has_seating")
  hasWifi      Boolean  @default(true) @map("has_wifi")
  createdOn    DateTime @default(now()) @map("created_on")
  updatedOn    DateTime @updatedAt @map("updated_on")
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shop_details")
}

model User {
  id           Int      @id @default(autoincrement())
  phone        String   @unique
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdOn    DateTime @default(now()) @map("created_on")
  updatedOn    DateTime @updatedAt @map("updated_on")
  shopId       Int      @map("shop_id")
  isActive     Boolean  @default(true) @map("is_active")
  role         UserRole @default(STAFF)
  orders       Order[]
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Category {
  id          Int          @id @default(autoincrement())
  shopId      Int          @map("shop_id")
  name        String
  type        CategoryType @default(DRINK)
  description String?
  createdOn   DateTime     @default(now()) @map("created_on")
  updatedOn   DateTime     @updatedAt @map("updated_on")
  shop        Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([shopId, name])
  @@map("categories")
}

model Product {
  id                Int               @id @default(autoincrement())
  shopId            Int               @map("shop_id")
  categoryId        Int?              @map("category_id")
  name              String
  description       String?
  basePrice         Decimal           @map("base_price") @db.Decimal(10, 2)
  size              String?
  isCustomizable    Boolean           @default(false) @map("is_customizable")
  sku               String?           @unique
  barcode           String?
  stock             Int               @default(-1)
  unit              String?           @default("unit")
  lowStockThreshold Int?              @default(10) @map("low_stock_threshold")
  isActive          Boolean           @default(true) @map("is_active")
  createdOn         DateTime          @default(now()) @map("created_on")
  updatedOn         DateTime          @updatedAt @map("updated_on")
  imageUrl          String?           @map("image_url")
  orderItems        OrderItem[]
  productModifiers  ProductModifier[]
  category          Category?         @relation(fields: [categoryId], references: [id])
  shop              Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplierProducts  SupplierProduct[]

  @@map("products")
}

model Modifier {
  id               Int               @id @default(autoincrement())
  shopId           Int               @map("shop_id")
  name             String
  price            Decimal           @db.Decimal(8, 2)
  group            String?
  createdOn        DateTime          @default(now()) @map("created_on")
  updatedOn        DateTime          @updatedAt @map("updated_on")
  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  productModifiers ProductModifier[]

  @@map("modifiers")
}

model ProductModifier {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  modifierId Int      @map("modifier_id")
  isDefault  Boolean  @default(false) @map("is_default")
  modifier   Modifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, modifierId])
  @@map("product_modifiers")
}

model Customer {
  id            Int      @id @default(autoincrement())
  shopId        Int      @map("shop_id")
  name          String
  phone         String?  @unique
  email         String?
  loyaltyPoints Int      @default(0) @map("loyalty_points")
  createdOn     DateTime @default(now()) @map("created_on")
  updatedOn     DateTime @updatedAt @map("updated_on")
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@map("customers")
}

model Order {
  id            Int           @id @default(autoincrement())
  shopId        Int           @map("shop_id")
  customerId    Int?          @map("customer_id")
  userId        Int           @map("user_id")
  orderNumber   String        @unique @map("order_number")
  status        OrderStatus   @default(PENDING)
  type          OrderType     @default(IN_STORE)
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal?      @default(0) @db.Decimal(10, 2)
  tax           Decimal?      @default(0) @db.Decimal(10, 2)
  finalAmount   Decimal       @map("final_amount") @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  notes         String?
  createdOn     DateTime      @default(now()) @map("created_on")
  updatedOn     DateTime      @updatedAt @map("updated_on")
  orderItems    OrderItem[]
  customer      Customer?     @relation(fields: [customerId], references: [id])
  shop          Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id                Int      @id @default(autoincrement())
  orderId           Int      @map("order_id")
  productId         Int      @map("product_id")
  quantity          Int      @default(1)
  unitPrice         Decimal  @map("unit_price") @db.Decimal(10, 2)
  subtotal          Decimal  @db.Decimal(12, 2)
  selectedModifiers Json?    @map("selected_modifiers")
  createdOn         DateTime @default(now()) @map("created_on")
  updatedOn         DateTime @updatedAt @map("updated_on")
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Supplier {
  id               Int               @id @default(autoincrement())
  shopId           Int               @map("shop_id")
  name             String
  contactPerson    String?           @map("contact_person")
  phone            String?
  email            String?
  createdOn        DateTime          @default(now()) @map("created_on")
  updatedOn        DateTime          @updatedAt @map("updated_on")
  supplierProducts SupplierProduct[]
  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("suppliers")
}

model SupplierProduct {
  supplierId  Int      @map("supplier_id")
  productId   Int      @map("product_id")
  supplyPrice Decimal  @map("supply_price") @db.Decimal(10, 2)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([supplierId, productId])
  @@map("supplier_products")
}

enum UserRole {
  ADMIN
  MANAGER
  BARISTA
  CASHIER
  STAFF
  OWNER
}

enum CategoryType {
  DRINK
  FOOD
  SUPPLY
  BEAN
  SYRUP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  IN_STORE
  TAKEAWAY
  DELIVERY
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  QR_CODE
  OTHER
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  REFUNDED
}
